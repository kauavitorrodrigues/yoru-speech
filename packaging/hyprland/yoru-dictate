#!/usr/bin/env python3
"""Dictation helper for Yoru Speech: sends start_recording/stop_recording
over the daemon's IPC socket. `toggle` picks start or stop based on a local
marker file, so a single key bind works even on compositors whose release
event ("bindr" and equivalents) isn't delivered reliably; `start`/`stop` remain
for compositors where a press/release bind does work."""
import json
import os
import shutil
import socket
import subprocess
import sys
import time

# A key press/release bind fires on the raw hardware event, with no
# minimum hold duration of its own: an accidental tap would otherwise
# still start and stop a real session, producing a near-empty transcript
# that overwrites the clipboard. Below this threshold, stop cancels the
# session instead of asking for a transcript.
MIN_HOLD_SECONDS = 0.15


def socket_path():
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR", "/tmp")
    return os.path.join(runtime_dir, "yoru-speech.sock")


def start_time_path():
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR", "/tmp")
    return os.path.join(runtime_dir, "yoru-dictate-start-time")


def send(command):
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    sock.settimeout(5)
    sock.connect(socket_path())
    sock.send((json.dumps(command) + "\n").encode())
    data = sock.recv(65536)
    sock.close()
    return json.loads(data.decode())


def notify(title, message):
    if shutil.which("notify-send") is None:
        return
    subprocess.run(["notify-send", title, message], check=False)


def do_start():
    response = send({"type": "start_recording"})
    if response.get("ok", False):
        with open(start_time_path(), "w") as f:
            f.write(repr(time.monotonic()))
    else:
        notify("Yoru Speech", "could not start: " + response.get("error", "unknown error"))


def do_stop(check_min_hold):
    held_seconds = None
    try:
        with open(start_time_path()) as f:
            held_seconds = time.monotonic() - float(f.read())
        os.remove(start_time_path())
    except (OSError, ValueError):
        pass  # No record of a start (e.g. daemon restarted); fall through to stop_recording.

    if check_min_hold and held_seconds is not None and held_seconds < MIN_HOLD_SECONDS:
        send({"type": "cancel_session"})
        return

    response = send({"type": "stop_recording"})
    if response.get("ok", False):
        notify("Yoru Speech", response.get("text", "").strip() or "(no speech detected)")
    else:
        notify("Yoru Speech", "error: " + response.get("error", "unknown error"))


def main():
    if len(sys.argv) != 2 or sys.argv[1] not in ("start", "stop", "toggle"):
        print("usage: yoru-dictate start|stop|toggle", file=sys.stderr)
        sys.exit(1)

    requested = sys.argv[1]
    # The marker file left by do_start() is also this process's only way to
    # know, from a single discrete key press, which direction a toggle
    # should go.
    action = requested
    if requested == "toggle":
        action = "stop" if os.path.exists(start_time_path()) else "start"

    try:
        if action == "start":
            do_start()
        else:
            # The min-hold-cancel guard exists for a press/release bind,
            # where an accidental tap of a shared modifier key can fire both
            # halves within milliseconds. A toggle press is a deliberate,
            # standalone action, so it always asks for a transcript.
            do_stop(check_min_hold=(requested == "stop"))
    except (OSError, ConnectionError) as error:
        notify("Yoru Speech", "daemon not reachable: " + str(error))


if __name__ == "__main__":
    main()
